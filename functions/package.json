{
  "name": "olimpiades-functions",
  "private": true,
  "version": "0.1.0",
  "description": "Cloud Functions per a Olimpiades (sincronització de custom claims).",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "olimpiades-app": "file:.."
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
