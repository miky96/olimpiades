rules_version = '2';

// Reglament base per a l'MVP.
// - Participants (públic sense login): poden llegir classificacions i dades
//   derivades, mai escriure.
// - Admins i superadmins: poden escriure. El rol i l'estat es llegeixen dels
//   custom claims del token (sincronitzats des de /users/{uid} per la Cloud
//   Function `syncUserClaims`). Així evitem un `get()` per regla.
//
// Si un admin acaba d'editar el seu propi rol, el token actual encara pot
// portar les claims antigues fins al següent refresc (~1h o `getIdToken(true)`).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return request.auth.token.role;
    }

    function userStatus() {
      return request.auth.token.status;
    }

    function isActiveAdmin() {
      return isSignedIn()
        && userStatus() == 'active'
        && (userRole() == 'admin' || userRole() == 'superadmin');
    }

    function isSuperAdmin() {
      return isSignedIn()
        && userStatus() == 'active'
        && userRole() == 'superadmin';
    }

    // --- Gestió d'usuaris (només superadmin) ---
    // La lectura del propi doc no depèn de claims: així un usuari acabat de
    // crear pot carregar el seu perfil encara que la Cloud Function no hagi
    // propagat les claims (cosa que pot trigar uns segons al primer alta).
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // --- Temporades i continguts relacionats ---
    // Lectura pública; escriptura només admins.
    match /seasons/{seasonId} {
      allow read: if true;
      allow create, update: if isActiveAdmin();
      allow delete: if isSuperAdmin();

      match /participants/{participantId} {
        allow read: if true;
        allow write: if isActiveAdmin();
      }

      match /events/{eventId} {
        allow read: if true;
        allow write: if isActiveAdmin();

        match /teams/{teamId} {
          allow read: if true;
          allow write: if isActiveAdmin();
        }

        match /attendance/{participantId} {
          allow read: if true;
          allow write: if isActiveAdmin();
        }

        match /matches/{matchId} {
          allow read: if true;
          allow write: if isActiveAdmin();
        }

        // Rondes de puntuació del format `points_league_bracket`.
        // Lectura pública (per al rànquing); escriptura només admins.
        match /pointsRounds/{roundId} {
          allow read: if true;
          allow write: if isActiveAdmin();
        }

        match /finalStandings/{docId} {
          allow read: if true;
          allow write: if isActiveAdmin();
        }
      }
    }
  }
}
